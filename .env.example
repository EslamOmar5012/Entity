# ============================================================
# ENTITY Website — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control (it's in .gitignore).

# -----------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------

# Set to "true"  → fetch all data live from Supabase
# Set to "false" → use built-in static/mock data (offline mode)
VITE_USE_SUPABASE=false

# -----------------------------------------------------------
# Supabase Credentials
# (Only needed when VITE_USE_SUPABASE=true)
# Find these at: Supabase Dashboard → Settings → API
# -----------------------------------------------------------

# Your project URL  (e.g. https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# NEW format (Supabase 2025): Publishable Key — safe for frontend, respects RLS
# Copy from: Dashboard → Settings → API Keys → "Publishable key"
VITE_SUPABASE_PUBLISHABLE_KEY=

# LEGACY format (pre-2025): Anon JWT key — still works during the migration period
# Copy from: Dashboard → Settings → API → "anon public"
# VITE_SUPABASE_ANON_KEY=
